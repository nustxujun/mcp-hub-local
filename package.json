{
  "name": "mcp-hub-local",
  "version": "0.2.1",
  "type": "module",
  "bin": {
    "mcp-hub-local": "./bin/mcp-hub-local.mjs"
  },
  "files": [
    "bin/",
    "apps/server/dist/",
    "apps/server/package.json",
    "apps/web/dist/",
    "apps/web/package.json",
    "packages/shared/dist/",
    "packages/shared/package.json",
    "packages/config-kit/dist/",
    "packages/config-kit/package.json",
    "packages/client-profiles/dist/",
    "packages/client-profiles/package.json",
    "LICENSE",
    "README.md"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "@mcp-hub-local/shared": "file:packages/shared",
    "@mcp-hub-local/config-kit": "file:packages/config-kit",
    "@mcp-hub-local/client-profiles": "file:packages/client-profiles",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.44.1",
    "fastify": "^5.3.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0",
    "smol-toml": "^1.4.1"
  },
  "bundleDependencies": [
    "@mcp-hub-local/shared",
    "@mcp-hub-local/config-kit",
    "@mcp-hub-local/client-profiles"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/server",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/config-kit && npm run build --workspace=packages/client-profiles && npm run build --workspace=apps/server && npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/server",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
